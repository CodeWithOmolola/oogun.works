<script>
// ─── UTILS ───
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

// ─── STATUS BAR TIME ───
function updateTime(){
  const n=new Date();let h=n.getHours(),m=n.getMinutes();
  const ap=h>=12?'PM':'AM';h=h%12||12;
  const t=h+':'+(m<10?'0'+m:m)+' '+ap;
  document.getElementById('status-time').textContent=t;
  const sbar=document.getElementById('sbar');
  if(sbar)sbar.textContent=t+'  ᯤ';
}
updateTime();setInterval(updateTime,30000);

// ─── HOME: live date + weather ───
(function(){
  const now=new Date();
  const days=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const months=['January','February','March','April','May','June','July','August','September','October','November','December'];
  const dateStr=days[now.getDay()]+', '+months[now.getMonth()]+' '+now.getDate();
  document.getElementById('home-date').textContent=dateStr;
  const h=now.getHours(),mi=now.getMinutes();
  const ap=h>=12?'PM':'AM';const hh=h%12||12;
  document.getElementById('bubble-ts').textContent='Today · '+hh+':'+(mi<10?'0'+mi:mi)+' '+ap;

  // use open-meteo's built-in IP geolocation — no extra API key needed
  fetch('https://ipapi.co/json/')
    .then(r=>r.json())
    .then(geo=>{
      const lat=geo.latitude,lon=geo.longitude,city=geo.city||'your city';
      return fetch('https://api.open-meteo.com/v1/forecast?latitude='+lat+'&longitude='+lon+'&current_weather=true&temperature_unit=fahrenheit')
        .then(r=>r.json())
        .then(wx=>{
          const temp=Math.round(wx.current_weather.temperature);
          const code=wx.current_weather.weathercode;
          const conds={0:'clear ☀️',1:'mostly clear ☀️',2:'partly cloudy ⛅',3:'overcast ☁️',45:'foggy 🌫️',51:'drizzly 🌦️',53:'drizzly 🌦️',61:'rainy 🌧️',63:'rainy 🌧️',71:'snowy 🌨️',80:'showery 🌦️',95:'stormy ⛈️'};
          const desc=conds[code]||'mild';
          document.getElementById('home-weather').textContent=temp+'°F and '+desc+' in '+city;
        });
    })
    .catch(()=>{
      // fallback: just show time-based greeting
      const hr=new Date().getHours();
      const feel=hr<12?'a crisp morning':'a warm afternoon';
      document.getElementById('home-weather').textContent=feel+' — check outside!';
    });
})();

// ─── HOME KEYBOARD (same keys as UX, non-interactive display) ───
(function(){
  const rows=[
    ['q','w','e','r','t','y','u','i','o','p'],
    ['a','s','d','f','g','h','j','k','l'],
    ['⇧','z','x','c','v','b','n','m','⌫'],
    ['123','space','↵']
  ];
  const kb=document.getElementById('home-kb');
  if(!kb)return;
  rows.forEach(keys=>{
    const row=document.createElement('div');row.className='kr';
    keys.forEach(k=>{
      const btn=document.createElement('button');btn.className='k';btn.textContent=k;
      if(k==='space')btn.classList.add('wide');
      if(['⇧','⌫','123','↵'].includes(k))btn.classList.add('gray');
      btn.style.pointerEvents='none';btn.style.opacity='0.7';
      row.appendChild(btn);
    });
    kb.appendChild(row);
  });
})();

// ─── CUBE NOTIFICATION ROTATOR ───
(function(){
  const notifications=[
    {icon:'📰',title:'The New York Times',sub:'Here\'s a guide to how you can keep up with the NYT, on and off Twitter.',time:'PINNED · 2 min ago'},
    {icon:'🐦',title:'X · Trending',sub:'"Allude" — 38K posts · AI device that shakes for answers is going viral.',time:'TRENDING · now'},
    {icon:'🎵',title:'Donna Summer',sub:'State of Independence is now playing on Spotify.',time:'NOW PLAYING'},
    {icon:'📅',title:'Google Calendar',sub:'No events scheduled today — a free day to explore.',time:'TODAY'},
  ];
  let idx=0,flipped=false;
  const cube=document.getElementById('notif-cube');
  const faceA=document.getElementById('notif-face-a');
  const faceB=document.getElementById('notif-face-b');

  function setFace(face,n){
    face.querySelector('.notif-icon').textContent=n.icon;
    face.querySelector('.notif-title').textContent=n.title;
    face.querySelector('.notif-sub').textContent=n.sub;
    face.querySelector('.notif-time').textContent=n.time;
  }

  setInterval(()=>{
    idx=(idx+1)%notifications.length;
    const n=notifications[idx];
    if(!flipped){
      setFace(faceB,n);
      cube.classList.add('flipped');
    }else{
      setFace(faceA,n);
      cube.classList.remove('flipped');
    }
    flipped=!flipped;
  },3500);
})();

// ─── BIRD → UX ───
document.getElementById('bird').addEventListener('click',()=>{
  showScreen('ux-screen');
  initUX();
});
document.getElementById('ux-back').addEventListener('click',()=>showScreen('home-screen'));

// ─── APP REDIRECTS ───
const appData={
  'spotify-btn':{name:'Spotify',icon:'🎵',bg:'#191414',isSpotify:true},
  'app-x':{name:'X',icon:'<svg viewBox="0 0 24 24" fill="#111" width="32" height="32"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.736-8.857L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',bg:'#000'},
  'app-tiktok':{name:'TikTok',icon:'🎵',bg:'#010101'},
  'app-google':{name:'Google',icon:'🔍',bg:'#fff'},
};

Object.keys(appData).forEach(id=>{
  const el=document.getElementById(id);
  if(!el)return;
  el.addEventListener('click',()=>{
    const d=appData[id];
    if(d.isSpotify){showScreen('spotify-screen');return;}
    document.getElementById('app-screen-name').textContent=d.name;
    const iconEl=document.getElementById('app-icon-big');
    iconEl.innerHTML=d.icon;
    iconEl.style.background=d.bg;
    showScreen('app-screen');
  });
});
document.getElementById('app-back').addEventListener('click',()=>showScreen('home-screen'));
document.getElementById('app-return-btn').addEventListener('click',()=>showScreen('home-screen'));
document.getElementById('sp-back').addEventListener('click',()=>showScreen('home-screen'));

// Spotify progress ticker
let spProgress=38,spPlaying=true;
setInterval(()=>{
  if(!spPlaying)return;
  spProgress=Math.min(spProgress+0.08,100);
  const fill=document.getElementById('sp-fill');
  if(fill)fill.style.width=spProgress+'%';
  const total=236,cur=Math.round(total*(spProgress/100));
  const m=Math.floor(cur/60),s=cur%60;
  const el=document.getElementById('sp-cur');
  if(el)el.textContent=m+':'+(s<10?'0'+s:s);
},1000);
document.getElementById('sp-play-btn').addEventListener('click',()=>{
  spPlaying=!spPlaying;
  const btn=document.getElementById('sp-play-btn');
  btn.innerHTML=spPlaying
    ?'<svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3" fill="white"/></svg>'
    :'<svg viewBox="0 0 24 24"><rect x="6" y="4" width="4" height="16" fill="white"/><rect x="14" y="4" width="4" height="16" fill="white"/></svg>';
});
document.querySelectorAll('.sp-track').forEach(t=>{
  t.addEventListener('click',function(){
    document.querySelectorAll('.sp-track').forEach(x=>{x.classList.remove('playing');const n=x.querySelector('.sp-t-num');if(n&&n.textContent==='▶')n.textContent='';});
    this.classList.add('playing');
    const numEl=this.querySelector('.sp-t-num');if(numEl)numEl.textContent='▶';
  });
});

// ─── UX SCREEN ───
let uxInitialized=false;

function initUX(){
  if(uxInitialized)return;
  uxInitialized=true;

  const tweets=[
    {h:'@beyoncegarden',s:'· 2m',b:'even APPLE MUSIC knows beyoncé\'s best work is lemonade, ICONIC 😭😭😭',img:'https://i.redd.it/yhzrkxdnxy1d1.jpeg'},
    {h:'@cnn',s:'· 1d',b:'French authorities have arrested two more suspects over a foiled attack on Bank of America\'s Paris offices.',img:'https://pbs.twimg.com/media/HElPlS1XMAAWGv2?format=jpg&name=small'},
    {h:'@forbes',s:'· 2d',b:'Seven years from now, the Social Security system will go bust. There isn\'t enough coming in from people still working to cover benefits.',img:'https://pbs.twimg.com/media/HEihIErbIAAtPfS?format=jpg&name=small'},
    {h:'@techfeed_x',s:'· 18m',b:'Google x X collab for a device that speaks Gen Z? About time #AI',img:'https://res.cloudinary.com/djmffrvpg/image/upload/v1774789712/Allude-DE-Profile_pwmmol.png'},
    {h:'@ambientshift',s:'· 24m',b:'The future of AI is ambient, not screen-based. Shake to ask is the natural next step 🤝',img:null},
  ];
  const xR=['X trending: "Allude" — 38K posts in 6 hours 🔥','Social pulse: 94% of X users want ambient AI over screen-based','Top X sentiment: people want AI that feels human, not robotic 💬','Breaking on X: Google & X device pre-orders up 220% this week'];
  const gR=[
    {n:'Ambient Computing',s:'A paradigm where computing is embedded in everyday objects, removing the need for screens.'},
    {n:'Voice-First AI',s:'AI systems designed for hands-free interaction — pioneered by Google Assistant, now evolving fast.'},
    {n:'Gen Z Tech Behavior',s:'72% of Gen Z prefer AI that integrates with social platforms as their primary info source. (Pew 2024)'},
    {n:'Magic 8 Ball (design heritage)',s:'Invented in 1950. The shake-to-answer interaction model has remained culturally intuitive for 70+ years.'},
  ];
  const tR=[
    {q:'beyonc',a:{t:'rich',n:'Beyoncé',s:'Singer-songwriter & entrepreneur. Renaissance World Tour grossed $580M globally.'}},
    {q:'what does allude',a:{t:'plain',v:'Allude bridges AI + social media. Shake ×2 for real-time X insights, ×3 for Google facts.'}},
    {q:'how does it work',a:{t:'plain',v:'Shake twice for X social insights. Shake three times for Google responses. Or type directly.'}},
    {q:'magic 8',a:{t:'rich',n:'Nostalgia as interface design',s:'The Magic 8 Ball succeeded because everyone already knows how to use it. Allude applies that same learned behavior to AI.'}},
    {q:'who is this for',a:{t:'rich',n:'Target: digital natives 18–38',s:'Gen Z and Millennials who treat social media as their primary info source.'}},
    {q:'why google',a:{t:'rich',n:'Google × X',s:'Google brings AI infrastructure. X provides real-time social context. Together they answer "what\'s true" and "what are people saying."'}},
    {q:'market',a:{t:'rich',n:'4.9 billion social media users',s:'No device bridges passive content consumption with intelligent assistance in a social-native format. Until now.'}},
    {q:'price',a:{t:'plain',v:'Premium positioning at $199–249. Available through Google Store and as an X Blue bundle.'}},
    {q:'who made',a:{t:'rich',n:'Omolola Ogunlade',s:'Brand strategist & speculative designer. See more at oogun.works'}},
    {q:'oogun',a:{t:'rich',n:'Oogun.works',s:'A creative consultancy built on Afromodernism as methodology. Understand · Make · Measure.'}},
    {q:'allude',a:{t:'plain',v:'Shake ×2 for X social insights, ×3 for Google knowledge base facts.'}},
    {q:'help',a:{t:'plain',v:'Try: "how does it work", "who made this", "what is the market" — or just shake.'}},
  ];

  async function fetchWeather(){
    try{
      const g=await(await fetch('https://ipapi.co/json/')).json();
      const wx=await(await fetch('https://api.open-meteo.com/v1/forecast?latitude='+g.latitude+'&longitude='+g.longitude+'&current_weather=true&temperature_unit=fahrenheit')).json();
      const temp=Math.round(wx.current_weather.temperature);
      const c={0:'Clear ☀️',1:'Mostly clear ☀️',2:'Partly cloudy ⛅',3:'Overcast ☁️',51:'Drizzle 🌦️',61:'Rain 🌧️',71:'Snow 🌨️',95:'Thunderstorms ⛈️'};
      return (c[wx.current_weather.weathercode]||'Mild')+' in '+g.city+' — '+temp+'°F.';
    }catch(e){return 'Unable to fetch weather right now.';}
  }

  function getTR(q){
    const lq=q.toLowerCase();
    if(lq.includes('weather')||lq.includes('temp')||lq.includes('outside'))return{t:'async',fn:fetchWeather};
    for(const r of tR){if(lq.includes(r.q))return r.a;}
    return{t:'plain',v:'Searching X and Google for "'+q+'"... Found '+Math.floor(Math.random()*800+100)+' posts.'};
  }

  let tIdx=0,typed='',shakeCount=0,overlayOpen=false,numMode=false;
  const tsEl=document.getElementById('ts');
  const cwEl=document.getElementById('cw');
  const kbtEl=document.getElementById('kbt');
  const ovEl=document.getElementById('ov');
  const ringEl=document.getElementById('ring');
  const sctEl=document.getElementById('sct');
  const scsEl=document.getElementById('scs');
  const askBtn=document.getElementById('askbtn');
  const p2El=document.getElementById('p2');
  const p3El=document.getElementById('p3');
  const shakeBtn=document.getElementById('shakeBtn');
  const sendBtn=document.getElementById('sendBtn');

  tweets.forEach((t,i)=>{
    const d=document.createElement('div');
    d.className='tc'+(i===0?' vis':'');
    const img=t.img?'<img class="ti" src="'+t.img+'" onerror="this.style.display=\'none\'" alt="">':'';
    d.innerHTML='<div class="th"><svg width="10" height="10" viewBox="0 0 24 24" fill="#1a72c4"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.736-8.857L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>'+t.h+' <span>'+t.s+'</span></div><div class="tb">'+t.b+'</div>'+img+'<div class="tf">View on X →</div>';
    tsEl.appendChild(d);
  });

  function cycleTweet(){
    const cards=[...tsEl.querySelectorAll('.tc')];
    cards[tIdx].classList.add('out');
    setTimeout(()=>{
      cards[tIdx].classList.remove('vis','out');
      tIdx=(tIdx+1)%tweets.length;
      cards[tIdx].classList.add('vis');
    },480);
  }
  setInterval(cycleTweet,3500);

  const MAX_MSGS=3;
  function pruneIfNeeded(){
    const msgs=[...cwEl.querySelectorAll('.msg')];
    if(msgs.length>=MAX_MSGS){msgs[0].classList.add('fade');setTimeout(()=>msgs[0].remove(),400);}
  }
  function addMsg(content,cls,delay){
    return new Promise(res=>{
      setTimeout(()=>{
        pruneIfNeeded();
        setTimeout(()=>{
          const el=document.createElement('div');el.className='msg '+cls;
          if(cls==='mr'){el.innerHTML='<div class="rn">'+content.n+'</div><div class="rs">'+content.s+'</div><span class="rl">Read more on Google →</span>';}
          else{el.textContent=content;}
          cwEl.appendChild(el);void el.offsetWidth;el.classList.add('show');res(el);
        },120);
      },delay||0);
    });
  }

  setTimeout(()=>addMsg('Try asking me anything...','mu',0),400);

  const kbA=[['q','w','e','r','t','y','u','i','o','p'],['a','s','d','f','g','h','j','k','l'],['⇧','z','x','c','v','b','n','m','⌫'],['123','space','↵']];
  const kbN=[['1','2','3','4','5','6','7','8','9','0'],['-','/',':',';','(',')','$','&','@','"'],['#','+','=','_','!','?','.',',','⌫'],['ABC','space','↵']];
  const kbEl=document.getElementById('kb');

  function buildKeyboard(){
    kbEl.innerHTML='';
    const rows=numMode?kbN:kbA;
    rows.forEach(keys=>{
      const row=document.createElement('div');row.className='kr';
      keys.forEach(k=>{
        const btn=document.createElement('button');btn.className='k';btn.textContent=k;
        if(k==='space')btn.classList.add('wide');
        if(['⇧','⌫','123','ABC'].includes(k))btn.classList.add('gray');
        if(k==='↵')btn.classList.add('gray');
        btn.addEventListener('mousedown',e=>{
          e.preventDefault();e.stopPropagation();
          if(k==='⌫'){typed=typed.slice(0,-1);}
          else if(k==='space'){typed+=' ';}
          else if(k==='↵'){submitTyped();return;}
          else if(k==='123'){numMode=true;buildKeyboard();return;}
          else if(k==='ABC'){numMode=false;buildKeyboard();return;}
          else if(k==='⇧')return;
          else typed+=k;
          kbtEl.textContent=typed;
        });
        row.appendChild(btn);
      });
      kbEl.appendChild(row);
    });
  }
  buildKeyboard();

  function submitTyped(){
    if(!typed.trim())return;
    const q=typed.trim();typed='';kbtEl.textContent='';
    addMsg(q,'mu',0);
    const resp=getTR(q);
    if(resp.t==='async'){resp.fn().then(r=>addMsg(r,'ma',0));}
    else setTimeout(()=>{if(resp.t==='rich')addMsg({n:resp.n,s:resp.s},'mr',0);else addMsg(resp.v,'ma',0);},950);
  }

  sendBtn.addEventListener('click',e=>{e.stopPropagation();submitTyped();});

  function openOverlay(){
    shakeCount=0;overlayOpen=true;ovEl.classList.add('on');
    sctEl.textContent='× 0';scsEl.textContent='click the shake button below to count';
    p2El.classList.remove('on');p3El.classList.remove('on');
    askBtn.classList.remove('ready');document.getElementById('cue').style.opacity='0.4';
  }
  function doShake(){
    if(shakeCount>=3)return;
    shakeCount++;
    ringEl.classList.remove('pop');void ringEl.offsetWidth;ringEl.classList.add('pop');
    sctEl.textContent='× '+shakeCount;
    const dev=document.getElementById('device');
    dev.style.transition='transform 0.08s';
    dev.style.transform=shakeCount%2===0?'rotate(-2deg)':'rotate(2deg)';
    setTimeout(()=>{dev.style.transform='';},110);
    if(shakeCount===1)scsEl.textContent='one more for X insights, keep going for Google...';
    if(shakeCount===2){scsEl.textContent='×2 ready — X social insights unlocked';p2El.classList.add('on');askBtn.classList.add('ready');}
    if(shakeCount===3){scsEl.textContent='×3 ready — Google knowledge base unlocked';p3El.classList.add('on');document.getElementById('cue').style.opacity='0';}
  }

  shakeBtn.addEventListener('click',e=>{
    e.stopPropagation();
    if(!overlayOpen)openOverlay();else doShake();
  });
  askBtn.addEventListener('click',e=>{
    e.stopPropagation();overlayOpen=false;ovEl.classList.remove('on');
    if(shakeCount>=3){
      const r=gR[Math.floor(Math.random()*gR.length)];
      addMsg('Google search...','mu',0);setTimeout(()=>addMsg({n:r.n,s:r.s},'mr',0),950);
    }else{
      const r=xR[Math.floor(Math.random()*xR.length)];
      addMsg("What's trending on X?","mu",0);setTimeout(()=>addMsg(r,'ma',0),900);cycleTweet();
    }
    shakeCount=0;
  });
}
</script>

