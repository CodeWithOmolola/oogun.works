<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Allude</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}

:root{
–blue:#1a72c4;
–blue-dark:#0d4a8a;
–white:#fff;
–ink:#0a0a0a;
}

body{
font-family:‘DM Sans’,sans-serif;
background:#0a0a0a;
display:flex;
align-items:center;
justify-content:center;
min-height:100vh;
padding:20px;
}

/* ═══ DEVICE SHELL ═══ */
.device{
width:100%;
max-width:620px;
background:#0a0a0a;
border-radius:18px;
border:2px solid #1e1e1e;
overflow:hidden;
box-shadow:0 30px 80px rgba(0,0,0,0.7), 0 0 0 1px rgba(26,114,196,0.12);
position:relative;
}

/* ═══ STATUS BAR ═══ */
.statusbar{
background:var(–blue);
display:flex;
justify-content:space-between;
align-items:center;
padding:5px 12px;
font-family:‘Space Mono’,monospace;
font-size:9px;
color:rgba(255,255,255,0.8);
letter-spacing:0.05em;
}
.status-brand{font-weight:700;color:white;}

/* ═══ SCREENS ═══ */
.screen{display:none;}
.screen.active{display:block;}

/* ═══════════════════════════
HOME SCREEN
═══════════════════════════ */
#home-screen .main{
background:var(–blue);
display:flex;
gap:0;
min-height:280px;
}

/* LEFT: bird + bubbles */
.home-left{
flex:1;
padding:12px 12px 12px;
border-right:1px solid rgba(255,255,255,0.15);
display:flex;
flex-direction:column;
justify-content:flex-end;
gap:0;
position:relative;
}

.bird-wrap{
display:flex;
align-items:flex-end;
gap:8px;
margin-top:6px;
padding-top:0;
}
.bird-placeholder{
width:52px;
height:52px;
border-radius:10px;
background:rgba(255,255,255,0.15);
border:1.5px dashed rgba(255,255,255,0.35);
cursor:pointer;
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
gap:3px;
flex-shrink:0;
transition:transform 0.2s, background 0.2s;
overflow:hidden;
}
.bird-placeholder:hover{transform:scale(1.08);background:rgba(255,255,255,0.22);}
.bird-placeholder img{
width:100%;height:100%;object-fit:cover;border-radius:8px;display:none;
}
.bird-placeholder-label{
font-size:7px;
color:rgba(255,255,255,0.5);
font-family:‘Space Mono’,monospace;
letter-spacing:0.05em;
text-align:center;
line-height:1.3;
}
.bird-hint{
font-size:8px;
color:rgba(255,255,255,0.45);
font-style:italic;
line-height:1.3;
}

.bubbles{display:flex;flex-direction:column;gap:7px;}

.bubble{
background:white;
border-radius:12px 12px 12px 3px;
padding:7px 10px;
font-size:9.5px;
color:#111;
line-height:1.45;
max-width:95%;
position:relative;
animation:bubblePop 0.3s ease both;
}
.bubble:nth-child(1){animation-delay:0.1s;}
.bubble:nth-child(2){animation-delay:0.35s;}

@keyframes bubblePop{
from{opacity:0;transform:translateY(6px) scale(0.96);}
to{opacity:1;transform:none;}
}

.bubble-time{
font-size:8px;
color:rgba(255,255,255,0.5);
margin-top:3px;
text-align:left;
}

.bubble strong{color:var(–blue);font-weight:600;}

/* RIGHT: notifications + apps */
.home-right{
flex:1.25;
padding:12px 12px 10px;
display:flex;
flex-direction:column;
gap:8px;
justify-content:space-between;
}

/* cube-flip notification */
.notif-scene{
perspective:400px;
height:72px;
flex-shrink:0;
}
.notif-cube{
width:100%;height:100%;
position:relative;
transform-style:preserve-3d;
transition:transform 0.7s cubic-bezier(0.4,0,0.2,1);
}
.notif-face{
position:absolute;inset:0;
background:white;
border-radius:9px;
padding:8px 10px;
display:flex;gap:8px;align-items:flex-start;
backface-visibility:hidden;
}
.notif-face.back{
transform:rotateX(180deg);
}
.notif-cube.flipped{
transform:rotateX(-180deg);
}
.notif-icon{
width:28px;height:28px;
border-radius:6px;
flex-shrink:0;
display:flex;align-items:center;justify-content:center;
font-size:14px;
background:#f0f4ff;
overflow:hidden;
}
.notif-icon img{width:100%;height:100%;object-fit:contain;}
.notif-body{flex:1;min-width:0;}
.notif-title{
font-size:9px;font-weight:600;color:#111;
margin-bottom:2px;
white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
.notif-sub{font-size:7.5px;color:#555;line-height:1.35;
display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.notif-time{font-size:7px;color:#aaa;margin-top:2px;}

/* app icons row — all 4 apps equal size */
.apps-row{
display:flex;
gap:8px;
align-items:center;
flex-wrap:wrap;
}
.app-icon{
width:40px;height:40px;
border-radius:10px;
cursor:pointer;
display:flex;align-items:center;justify-content:center;
transition:transform 0.15s, box-shadow 0.15s;
border:1.5px solid rgba(255,255,255,0.15);
overflow:hidden;
background:#111;
}
.app-icon:hover{transform:scale(1.1);box-shadow:0 4px 16px rgba(0,0,0,0.4);}
.app-icon:active{transform:scale(0.95);}
.app-icon img,.app-icon svg{width:22px;height:22px;object-fit:contain;}

/* bottom keyboard strip (home — decorative) */
.home-kbd{
background:#111318;
padding:10px 12px 12px;
display:flex;gap:10px;align-items:flex-start;
}
.kbd-area{flex:1;}
.kbd-row{display:flex;gap:3px;justify-content:center;margin-bottom:4px;}
.kbd-key{
background:#2a2a30;color:#888;border-radius:3px;
width:22px;height:20px;font-size:7.5px;
display:flex;align-items:center;justify-content:center;
font-family:‘DM Sans’,sans-serif;
}
.kbd-key.wide{width:56px;}
.kbd-key.gray{background:#222;}
.kbd-track{width:76px;height:60px;background:#1a1a1f;border-radius:6px;border:1px solid #2a2a30;}
.kbd-btns{display:flex;flex-direction:column;gap:7px;align-items:center;justify-content:center;}
.kbd-btn{
width:30px;height:30px;background:#1a1a1f;border-radius:50%;
border:1.5px solid #333;display:flex;align-items:center;justify-content:center;
}
.kbd-btn svg{width:11px;height:11px;stroke:#555;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}

/* ═══════════════════════════
INTERACTIVE UX SCREEN
═══════════════════════════ */
#ux-screen .ux-top{
display:flex;min-height:235px;background:var(–blue);
}
.ux-left{
flex:1.05;padding:12px 10px;border-right:1px solid rgba(255,255,255,0.15);
display:flex;flex-direction:column;gap:6px;overflow:hidden;
}
.ux-logo{
font-family:‘Space Mono’,monospace;font-size:14px;font-weight:700;
color:white;line-height:1.2;letter-spacing:0.04em;
}
.tweet-stage{flex:1;position:relative;overflow:hidden;border-radius:8px;min-height:110px;}
.tc{
position:absolute;inset:0;background:white;border-radius:8px;
padding:8px 10px;display:flex;flex-direction:column;gap:3px;
opacity:0;transform:translateY(14px);
transition:opacity 0.5s ease,transform 0.5s ease;pointer-events:none;
}
.tc.vis{opacity:1;transform:translateY(0);}
.tc.out{opacity:0;transform:translateY(-10px);}
.th{font-size:9.5px;font-weight:600;color:var(–blue);display:flex;align-items:center;gap:4px;}
.th span{color:#777;font-weight:400;}
.tb{font-size:10px;color:#222;line-height:1.4;flex:1;}
.ti{width:100%;height:52px;object-fit:cover;border-radius:5px;margin-top:2px;}
.tf{
font-size:9px;color:var(–blue);font-weight:500;cursor:pointer;
background:#e8f0fe;border-radius:4px;padding:2px 7px;
display:inline-block;margin-top:auto;align-self:flex-start;
}
.dots-row{display:flex;gap:4px;justify-content:center;}
.dot{width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,0.3);transition:background 0.3s;}
.dot.on{background:white;}

.ux-right{
flex:1;padding:10px 10px 8px 12px;display:flex;flex-direction:column;overflow:hidden;
}
.ux-sbar{
font-size:9px;color:rgba(255,255,255,0.75);text-align:right;
font-family:‘DM Sans’,sans-serif;margin-bottom:6px;flex-shrink:0;
}
.cw{
flex:1;display:flex;flex-direction:column;justify-content:flex-end;
gap:5px;overflow:hidden;min-height:0;
}
.msg{
border-radius:10px;padding:6px 9px;font-size:10px;line-height:1.35;
max-width:95%;transition:opacity 0.4s ease,transform 0.4s ease;
opacity:0;transform:translateY(8px);
}
.msg.show{opacity:1;transform:translateY(0);}
.msg.fade{opacity:0;transform:translateY(-6px);}
.mu{background:rgba(255,255,255,0.95);color:#111;align-self:flex-start;}
.ma{background:rgba(255,255,255,0.22);color:white;align-self:flex-end;}
.mr{background:white;color:#111;align-self:flex-end;padding:6px 8px;}
.rn{font-weight:600;font-size:10px;color:var(–blue);margin-bottom:1px;}
.rs{font-size:9px;color:#555;line-height:1.3;}
.rl{font-size:8.5px;color:var(–blue);text-decoration:underline;display:block;margin-top:2px;cursor:pointer;}
.ux-sh{font-size:9px;color:rgba(255,255,255,0.45);text-align:center;padding:4px 0 0;font-style:italic;flex-shrink:0;}

/* shake overlay */
.ov{
position:absolute;top:0;left:0;right:0;bottom:62px;
background:rgba(14,55,115,0.95);
display:flex;flex-direction:column;align-items:center;justify-content:center;
z-index:20;opacity:0;pointer-events:none;transition:opacity 0.3s;
border-radius:16px 16px 0 0;
}
.ov.on{opacity:1;pointer-events:all;}
.ring{
width:62px;height:62px;border:3px solid rgba(255,255,255,0.5);
border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:10px;
}
.ring.pop{animation:pop 0.25s ease;}
@keyframes pop{0%{transform:scale(1);}50%{transform:scale(1.2);}100%{transform:scale(1);}}
.sct{font-size:22px;color:white;font-family:‘DM Sans’,sans-serif;font-weight:700;}
.scs{font-size:10px;color:rgba(255,255,255,0.65);margin-top:6px;text-align:center;line-height:1.5;max-width:180px;}
.mpills{display:flex;gap:6px;margin-top:10px;}
.mp{
font-size:9px;border-radius:12px;padding:3px 10px;font-weight:600;
border:1.5px solid rgba(255,255,255,0.25);color:rgba(255,255,255,0.4);
font-family:‘Space Mono’,monospace;transition:all 0.25s;
}
.mp.on{border-color:white;color:white;background:rgba(255,255,255,0.18);}
.askbtn{
margin-top:14px;background:white;color:var(–blue);border:none;
border-radius:20px;padding:7px 24px;font-size:12px;font-weight:600;
cursor:pointer;font-family:‘DM Sans’,sans-serif;opacity:0.3;
pointer-events:none;transition:opacity 0.25s;
}
.askbtn.ready{opacity:1;pointer-events:all;}
.cue{font-size:9px;color:rgba(255,255,255,0.4);margin-top:8px;font-style:italic;}

/* UX keyboard */
.ux-bot{
background:var(–blue);border-top:2px solid #0a0a0a;
padding:10px 12px;display:flex;gap:10px;align-items:flex-start;
}
.kw{flex:1;}
.ib{
background:rgba(255,255,255,0.15);border-radius:6px;padding:5px 8px;
font-size:11px;color:white;min-height:24px;margin-bottom:5px;
display:flex;align-items:center;word-break:break-all;
}
.cur{
display:inline-block;width:1.5px;height:13px;background:white;
animation:blink 1s infinite;vertical-align:middle;margin-left:1px;
}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0;}}
.kr{display:flex;gap:4px;margin-bottom:4px;justify-content:center;}
.k{
background:white;color:#111;border-radius:4px;width:26px;height:26px;
font-size:11px;font-family:‘DM Sans’,sans-serif;font-weight:500;
border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;
transition:background 0.1s,transform 0.08s;flex-shrink:0;user-select:none;
}
.k:active{transform:scale(0.9);}
.k.wide{width:auto;padding:0 8px;flex:1;min-width:90px;}
.k.gray{background:#b0b0b0;}
.sc-col{display:flex;flex-direction:column;gap:8px;align-items:center;}
.tp{width:72px;height:52px;background:#777;border-radius:6px;border:1px solid rgba(255,255,255,0.2);}
.sbtn{
width:38px;height:38px;background:#2a2a2a;border-radius:50%;
display:flex;align-items:center;justify-content:center;
cursor:pointer;border:2px solid #444;
transition:background 0.15s,transform 0.1s;position:relative;z-index:30;
}
.sbtn:hover{background:#3a3a3a;}
.sbtn:active{transform:scale(0.92);}
.sbtn svg{width:16px;height:16px;fill:none;stroke:white;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}

/* back button (appears in ux) */
.back-btn{
position:absolute;top:8px;left:10px;z-index:50;
background:rgba(0,0,0,0.35);border:1px solid rgba(255,255,255,0.2);
color:rgba(255,255,255,0.7);border-radius:20px;
padding:3px 10px;font-size:8px;font-family:‘Space Mono’,monospace;
cursor:pointer;letter-spacing:0.08em;
transition:background 0.2s;
}
.back-btn:hover{background:rgba(0,0,0,0.6);}

/* ═══════════════════════════
SPOTIFY SCREEN
═══════════════════════════ */
#spotify-screen .sp-main{
background:#111;
min-height:280px;
display:flex;
gap:0;
}
.sp-left{
flex:1;
padding:16px 14px;
display:flex;
flex-direction:column;
align-items:center;
border-right:1px solid #1a1a1a;
}
.sp-big-art{
width:110px;height:110px;
border-radius:10px;
background:linear-gradient(135deg,#1DB954 0%,#191414 100%);
display:flex;align-items:center;justify-content:center;
font-size:44px;
margin-bottom:12px;
box-shadow:0 8px 24px rgba(0,0,0,0.5);
overflow:hidden;
}
.sp-big-art img{width:100%;height:100%;object-fit:cover;}
.sp-song-name{font-size:13px;font-weight:700;color:white;text-align:center;margin-bottom:2px;}
.sp-artist-name{font-size:10px;color:#aaa;text-align:center;margin-bottom:14px;}
.sp-prog-wrap{width:100%;}
.sp-bar{height:3px;background:#333;border-radius:3px;margin-bottom:4px;}
.sp-bar-fill{height:100%;width:38%;background:#1DB954;border-radius:3px;}
.sp-times{display:flex;justify-content:space-between;font-size:8px;color:#666;margin-bottom:12px;}
.sp-ctrl{display:flex;align-items:center;justify-content:center;gap:12px;}
.sp-c-btn{
width:26px;height:26px;background:none;border:none;cursor:pointer;
display:flex;align-items:center;justify-content:center;
}
.sp-c-btn svg{width:14px;height:14px;fill:#aaa;}
.sp-c-play{
width:38px;height:38px;background:#1DB954;border-radius:50%;
display:flex;align-items:center;justify-content:center;
}
.sp-c-play svg{width:16px;height:16px;fill:white;margin-left:2px;}

.sp-right{
flex:1;
padding:12px 10px;
overflow-y:auto;
}
.sp-queue-label{
font-family:‘Space Mono’,monospace;font-size:7.5px;
letter-spacing:0.18em;color:#555;margin-bottom:10px;
}
.sp-track{
display:flex;align-items:center;gap:8px;
padding:5px 6px;border-radius:6px;cursor:pointer;
transition:background 0.15s;
margin-bottom:3px;
}
.sp-track:hover{background:#1a1a1a;}
.sp-track.playing{background:#1a2a1a;}
.sp-t-num{font-size:8.5px;color:#555;width:12px;text-align:center;flex-shrink:0;}
.sp-t-art{
width:28px;height:28px;border-radius:4px;flex-shrink:0;
background:#222;display:flex;align-items:center;justify-content:center;font-size:13px;
overflow:hidden;
}
.sp-t-art img{width:100%;height:100%;object-fit:cover;}
.sp-t-info{flex:1;min-width:0;}
.sp-t-name{font-size:9px;color:#ddd;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sp-t-artist{font-size:8px;color:#666;}
.sp-t-dur{font-size:8px;color:#555;flex-shrink:0;}
.sp-track.playing .sp-t-name{color:#1DB954;}
.sp-track.playing .sp-t-num{color:#1DB954;}

.sp-kbd{
background:#0d0d0d;border-top:1px solid #1a1a1a;
padding:8px 12px 10px;
display:flex;gap:10px;align-items:flex-start;
}

/* ═══════════════════════════
APP REDIRECT SCREEN
═══════════════════════════ */
#app-screen .app-main{
background:var(–blue);
min-height:280px;
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
gap:16px;
padding:30px;
}
.app-big-icon{
width:64px;height:64px;border-radius:16px;
display:flex;align-items:center;justify-content:center;
background:#fff;
font-size:32px;
box-shadow:0 8px 32px rgba(0,0,0,0.3);
}
.app-name{font-family:‘Space Mono’,monospace;font-size:18px;font-weight:700;color:white;letter-spacing:0.05em;}
.app-msg{font-size:11px;color:rgba(255,255,255,0.6);text-align:center;line-height:1.6;max-width:240px;}
.app-return{
background:white;color:var(–blue);border:none;border-radius:20px;
padding:9px 24px;font-size:11px;font-weight:600;
cursor:pointer;font-family:‘DM Sans’,sans-serif;
margin-top:6px;transition:opacity 0.2s;
}
.app-return:hover{opacity:0.85;}
</style>

</head>
